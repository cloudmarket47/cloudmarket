# Active app runtime: Vite + React + Supabase
# Copy the values below into `.env.local` and replace the placeholders.

VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"
VITE_SUPABASE_REALTIME_ENABLED="true"

# Netlify Function email delivery
# Set the same values in your Netlify site environment variables.
GMAIL_USER="your-gmail-address@gmail.com"
GMAIL_APP_PASSWORD="your-16-character-gmail-app-password"
ORDER_NOTIFICATION_EMAIL="orders@your-domain.com"

# Meta Conversions API server-side purchase tracking
# The Pixel ID stays in admin settings. These values belong in Netlify environment variables too.
META_CONVERSIONS_API_ACCESS_TOKEN="your-meta-conversions-api-access-token"
META_CONVERSIONS_API_TEST_EVENT_CODE=""
META_CONVERSIONS_API_GRAPH_VERSION="v24.0"

# Optional table overrides
VITE_SUPABASE_TABLE_ANALYTICS_EVENTS="analytics_events"
VITE_SUPABASE_TABLE_APP_SETTINGS="app_settings"
VITE_SUPABASE_TABLE_CUSTOMER_TOKENS="customer_tokens"
VITE_SUPABASE_TABLE_FINANCE_EXPENSES="finance_expenses"
VITE_SUPABASE_TABLE_FINANCE_SALES="finance_sales"
VITE_SUPABASE_TABLE_ORDERS="orders"
VITE_SUPABASE_TABLE_PRODUCT_PAGES="product_pages"
VITE_SUPABASE_TABLE_SUBSCRIBER_ACTIVITIES="subscriber_activities"
VITE_SUPABASE_TABLE_SUBSCRIBER_MANAGEMENT="subscriber_management"

# Optional storage bucket override
VITE_SUPABASE_BUCKET_ASSETS="cloudmarket-assets"
